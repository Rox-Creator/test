local function DrawSlider(x, y, w, label, value, minV, maxV, valueFmt, onChange, zbase, helpText)
    local trackH, knobR, labelH = 6, 7, 16
    local trackY = y + labelH + 6
    local knobY  = trackY + trackH / 2

    local v = math.max(minV, math.min(maxV, value))
    local pct = (v - minV) / (maxV - minV)
    local fillW = w * pct
    local knobX = x + fillW

    local lbl = Drawing.new("Text")
    lbl.Position = Vector2.new(x, y)
    lbl.Text = label; lbl.Color = Colors.TextPrimary
    lbl.Size = 13; lbl.Font = Drawing.Fonts.System
    lbl.Center = false; lbl.Outline = false
    lbl.Visible = true; lbl.ZIndex = zbase + 5
    table.insert(GUI.ContentElements, lbl)

    if helpText then
        local labelEstW = #label * 7
        local helpX = x + labelEstW + 2
        local helpY = y

        local helpBg = Drawing.new("Circle")
        helpBg.Position = Vector2.new(helpX + 3, helpY + 7)
        helpBg.Radius = 8; helpBg.Color = Color3.new(0, 0, 0)
        helpBg.Filled = true; helpBg.NumSides = 24
        helpBg.Transparency = 0.55
        helpBg.Visible = true; helpBg.ZIndex = zbase + 4
        table.insert(GUI.ContentElements, helpBg)

        local helpIcon = Drawing.new("Text")
        helpIcon.Position = Vector2.new(helpX, helpY)
        helpIcon.Text = "?"; helpIcon.Color = Colors.TextMuted
        helpIcon.Size = 13; helpIcon.Font = Drawing.Fonts.SystemBold
        helpIcon.Center = false; helpIcon.Outline = false
        helpIcon.Visible = true; helpIcon.ZIndex = zbase + 5
        table.insert(GUI.ContentElements, helpIcon)

        table.insert(GUI.Clickables, {
            x = helpX - 4, y = helpY - 2, w = 16, h = 18,
            hover = { el = helpIcon, base = Colors.TextMuted },
            tooltip = helpText,
            onClick = function() end,
        })
    end

    local isEditing = GUI.EditingSlider and GUI.EditingSlider.label == label
    local valStr   = isEditing and (GUI.SliderBuffer .. "_") or string.format(valueFmt, v)
    local valTxtColor = isEditing and Colors.AccentRed or Colors.TextPrimary
    local valTxt = Drawing.new("Text")
    valTxt.Text = valStr
    valTxt.Color = valTxtColor
    valTxt.Size = 13; valTxt.Font = Drawing.Fonts.SystemBold
    valTxt.Center = false; valTxt.Outline = false
    valTxt.Visible = true; valTxt.ZIndex = zbase + 5
    valTxt.Position = Vector2.new(x + w - #valStr * 7, y)
    table.insert(GUI.ContentElements, valTxt)
    if isEditing then GUI.EditingSlider.valTxt = valTxt end

    local track = Drawing.new("Square")
    track.Position = Vector2.new(x, trackY); track.Size = Vector2.new(w, trackH)
    track.Color = Colors.ToggleOff; track.Filled = true; track.Corner = trackH / 2
    track.Visible = true; track.ZIndex = zbase + 3
    table.insert(GUI.ContentElements, track)

    local fill = Drawing.new("Square")
    fill.Position = Vector2.new(x, trackY)
    fill.Size = Vector2.new(math.max(0.001, fillW), trackH)
    fill.Color = Colors.AccentRed; fill.Filled = true; fill.Corner = trackH / 2
    fill.Visible = fillW > 0; fill.ZIndex = zbase + 4
    table.insert(GUI.ContentElements, fill)

    local knob = Drawing.new("Circle")
    knob.Position = Vector2.new(knobX, knobY)
    knob.Radius = knobR
    knob.Color = Color3.fromRGB(230, 234, 245)
    knob.Filled = true; knob.NumSides = 16
    knob.Visible = true; knob.ZIndex = zbase + 5
    table.insert(GUI.ContentElements, knob)

    local function setFromMouse()
        local pctClick = (Mouse.X - x) / w
        pctClick = math.max(0, math.min(1, pctClick))
        local newVal = minV + pctClick * (maxV - minV)
        local newFillW = w * pctClick
        local newKnobX = x + newFillW
        local newStr = string.format(valueFmt, newVal)
        pcall(function()
            knob.Position = Vector2.new(newKnobX, knobY)
            fill.Size = Vector2.new(math.max(0.001, newFillW), trackH)
            fill.Visible = newFillW > 0
            valTxt.Text = newStr
            valTxt.Position = Vector2.new(x + w - #newStr * 7, y)
        end)
        onChange(newVal)
    end

    local valHitW = 60
    local valHitX = x + w - valHitW
    local valHitY = y - 2
    local valHitH = 18
    table.insert(GUI.Clickables, {
        x = valHitX, y = valHitY, w = valHitW, h = valHitH,
        hover = { el = valTxt, base = valTxtColor },
        onClick = function()
            GUI.EditingSlider = {
                label    = label,
                minV     = minV,
                maxV     = maxV,
                onChange = onChange,
                valTxt   = valTxt,
            }
            GUI.SliderBuffer = ""
            GUI.SliderKeyState = {}
            notify("Type a number. Enter to save, Esc to cancel.", "AOT:R", 4)
            CreateContent()
        end,
    })

    table.insert(GUI.Clickables, {
        x = x - knobR, y = trackY - knobR,
        w = w + 2 * knobR, h = trackH + 2 * knobR,
        sliderDrag = setFromMouse,
        onClick = setFromMouse,
    })

    return trackY + trackH + 6
end

