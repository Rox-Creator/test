-- Returns nearest titan that still has a Humanoid, with both the
-- titan model and its nape. Returns nil, nil if none.
local function getNearestLiveTitan()
    local titansFolder = Workspace:FindFirstChild("Titans")
    if not titansFolder then return nil, nil end
    local hrp = getHRP()
    if not hrp then return nil, nil end
    local okPP, pPos = pcall(function() return hrp.Position end)
    if not (okPP and pPos) then return nil, nil end
    local bestTitan, bestNape, bestD2 = nil, nil, math.huge
    for _, titan in ipairs(titansFolder:GetChildren()) do
        if findHumanoid(titan) then
            local nape = getNape(titan)
            if nape then
                local okN, npos = pcall(function() return nape.Position end)
                if okN and npos then
                    local dx = pPos.X - npos.X
                    local dy = pPos.Y - npos.Y
                    local dz = pPos.Z - npos.Z
                    local d2 = dx*dx + dy*dy + dz*dz
                    if d2 < bestD2 then
                        bestD2 = d2; bestTitan = titan; bestNape = nape
                    end
                end
            end
        end
    end
    return bestTitan, bestNape
end

-- Best per-titan height signal we have without instance attributes
-- (Matcha's GetAttribute is unreliable on Model). The HRP scales
-- with titan tier (3m / 7m / 10m / 15m), so its Size.Y is a clean
-- proxy. Falls back to nape Y position if HRP isn't available.
local function getTitanHeight(titan)
    local hrp
    pcall(function() hrp = titan:FindFirstChild("HumanoidRootPart") end)
    if hrp then
        local okSz, sz = pcall(function() return hrp.Size end)
        if okSz and sz and sz.Y then return sz.Y end
    end
    local nape = getNape(titan)
    if nape then
        local okP, p = pcall(function() return nape.Position end)
        if okP and p and p.Y then return p.Y end
    end
    return 0
end

-- Returns the live titan with the largest HRP (= tallest tier).
-- Used by AutoKill so the player chops down 15m+ titans before
-- smaller ones — they hit harder and matter more.
local function getTallestLiveTitan()
    local titansFolder = Workspace:FindFirstChild("Titans")
    if not titansFolder then return nil, nil end
    local bestTitan, bestNape, bestH = nil, nil, -math.huge
    for _, titan in ipairs(titansFolder:GetChildren()) do
        if findHumanoid(titan) then
            local nape = getNape(titan)
            if nape then
                local h = getTitanHeight(titan)
                if h > bestH then
                    bestH = h; bestTitan = titan; bestNape = nape
                end
            end
        end
    end
    return bestTitan, bestNape
end

-- Generic nearest-to-anchor targeting. Used by Raid to prioritise
-- titans by distance to a fixed map landmark instead of by tier.
-- Falls back to tallest if the anchor can't be read so we never
-- end up with no target at all.
local function getNearestLiveTitanToAnchor(anchor)
    if not anchor then return getTallestLiveTitan() end

    local titansFolder = Workspace:FindFirstChild("Titans")
    if not titansFolder then return nil, nil end
    local bestT, bestN, bestD2 = nil, nil, math.huge
    for _, titan in ipairs(titansFolder:GetChildren()) do
        if findHumanoid(titan) then
            local nape = getNape(titan)
            if nape then
                local okPos, pos = pcall(function() return nape.Position end)
                if okPos and pos then
                    local dx = pos.X - anchor.X
                    local dy = pos.Y - anchor.Y
                    local dz = pos.Z - anchor.Z
                    local d2 = dx*dx + dy*dy + dz*dz
                    if d2 < bestD2 then bestD2, bestT, bestN = d2, titan, nape end
                end
            end
        end
    end
    return bestT, bestN
end

-- Eren-Raid phase-1 anchor: the BigRock model that Eren hides
-- behind while charging the titan-cannon. We want to keep titans
-- away from it so they can't break the rock and expose Eren. Path:
--   Workspace.Unclimbable.Objective.Defend_Eren.BigRock
local function getRaidAnchorPos()
    local rock
    pcall(function()
        rock = Workspace
            and Workspace:FindFirstChild("Unclimbable")
            and Workspace.Unclimbable:FindFirstChild("Objective")
            and Workspace.Unclimbable.Objective:FindFirstChild("Defend_Eren")
            and Workspace.Unclimbable.Objective.Defend_Eren:FindFirstChild("BigRock")
    end)
    if not rock then return nil end

    local okPP, pp = pcall(function() return rock.PrimaryPart end)
    if okPP and pp then
        local okP, p = pcall(function() return pp.Position end)
        if okP and p then return p end
    end

    -- Fall back to the rock's own Position (it's likely a single
    -- BasePart, not a Model). Then average descendant positions if
    -- it turns out to be a Model with no PrimaryPart.
    local okP, p = pcall(function() return rock.Position end)
    if okP and p and p.X then return p end

    local descs
    pcall(function() descs = rock:GetDescendants() end)
    if not descs then return nil end
    local sx, sy, sz, n = 0, 0, 0, 0
    for _, d in ipairs(descs) do
        local okP2, p2 = pcall(function() return d.Position end)
        if okP2 and p2 and p2.X then
            sx = sx + p2.X; sy = sy + p2.Y; sz = sz + p2.Z; n = n + 1
        end
    end
    if n > 0 then return Vector3.new(sx / n, sy / n, sz / n) end
    return nil
end

local function getNearestLiveTitanToRaidAnchor()
    return getNearestLiveTitanToAnchor(getRaidAnchorPos())
end

-- Phase-2 detection. Eren spawns into Workspace.Titans as a model
-- named "Attack_Titan" once phase 2 starts. While he's alive we
-- target him exclusively (ignore the trash titans that spawn
-- alongside); before he appears we fall back to phase-1 BigRock-
-- anchored targeting.
local function getErenTitan()
    local titans = Workspace:FindFirstChild("Titans")
    if not titans then return nil end
    local eren = titans:FindFirstChild("Attack_Titan")
    if not eren then return nil end
    if not findHumanoid(eren) then return nil end
    return eren
end

local function getRaidTarget()
    local eren = getErenTitan()
    if eren then
        local nape = getNape(eren)
        if nape then return eren, nape end
    end
    return getNearestLiveTitanToRaidAnchor()
end

-- Detects whether the target titan currently has any "*grab*"
-- attribute set, e.g. Left_nape_grab / Right_nape_grab / Left_air_grab
-- / right_air_grab. AOT:R sets these mid-grab animation. The Auto Kill
-- loop bails (TPs high, freezes 0.5s) when any of these go true so
-- the player isn't held inside the titan's grab hitbox.
local function isTitanGrabbing(titan)
    if not titan then return false end
    local attrs
    pcall(function() attrs = titan:GetAttributes() end)
    if type(attrs) ~= "table" then return false end
    for k, v in pairs(attrs) do
        if v and string.find(string.lower(tostring(k)), "grab") then
            return true
        end
    end
    return false
end

-- Detects whether the Attack_Titan is in the "Roar" state. We
-- read the State attribute by name via GetAttribute (singular) —
-- the plural GetAttributes only returns names, but the singular
-- call returns the actual value. State is a string ("Idle",
-- "Roar", "Hardening", etc.).
local function isTitanRoaring(titan)
    if not titan then return false end
    local ok, state = pcall(function() return titan:GetAttribute("State") end)
    if not (ok and type(state) == "string") then return false end
    return string.find(string.lower(state), "roar", 1, true) ~= nil
end

-- Reads the "X / Y" blade-sets counter from the HUD. Returns the
-- remaining set count as a number, or nil if the label can't be read.
-- Path: PlayerGui.Interface.HUD.Main.Top["7"].Blades.Sets
local function getBladeSets()
    local pg     = LocalPlayer:FindFirstChild("PlayerGui")
    local iface  = pg     and pg:FindFirstChild("Interface")
    local hud    = iface  and iface:FindFirstChild("HUD")
    local main   = hud    and hud:FindFirstChild("Main")
    local top    = main   and main:FindFirstChild("Top")
    local seven  = top    and top:FindFirstChild("7")
    local blades = seven  and seven:FindFirstChild("Blades")
    local sets   = blades and blades:FindFirstChild("Sets")
    if not sets then return nil end
    local okT, txt = pcall(function() return sets.Text end)
    if not (okT and type(txt) == "string") then return nil end
    return tonumber(txt:match("(%d+)"))
end

-- Walks every "Refill" descendant in Workspace whose parent is a
-- "GasTanks" model and returns the one nearest the player. Covers
-- gas tanks anywhere on the map, not just the wall-mounted ones.
local function getNearestRefill()
    local hrp = getHRP()
    if not hrp then return nil end
    local okP, pPos = pcall(function() return hrp.Position end)
    if not (okP and pPos) then return nil end

    local descs
    pcall(function() descs = Workspace:GetDescendants() end)
    if not descs then return nil end

    local bestPart, bestD2 = nil, math.huge
    for _, d in ipairs(descs) do
        local okN, name = pcall(function() return d.Name end)
        if okN and name == "Refill" then
            local par
            pcall(function() par = d.Parent end)
            local parName
            if par then pcall(function() parName = par.Name end) end
            if parName == "GasTanks" then
                local okR, rPos = pcall(function() return d.Position end)
                if okR and rPos then
                    local dx = pPos.X - rPos.X
                    local dy = pPos.Y - rPos.Y
                    local dz = pPos.Z - rPos.Z
                    local d2 = dx*dx + dy*dy + dz*dz
                    if d2 < bestD2 then bestD2 = d2; bestPart = d end
                end
            end
        end
    end
    return bestPart
end

-- Reads the Quantity TextLabel of a single rewards-screen item slot.
-- Slots are named "<row>_<col>" — EXP is always 1_1, Gold always 1_2
-- in AOT:R's mission-completed UI. Strips commas ("16,704" → 16704)
-- and returns a number, or nil if the slot / label can't be read.
local function getRewardItemQuantity(slotName)
    local pg     = LocalPlayer:FindFirstChild("PlayerGui")
    local iface  = pg     and pg:FindFirstChild("Interface")
    local rew    = iface  and iface:FindFirstChild("Rewards")
    local mainA  = rew    and rew:FindFirstChild("Main")
    local info   = mainA  and mainA:FindFirstChild("Info")
    local mainB  = info   and info:FindFirstChild("Main")
    local items  = mainB  and mainB:FindFirstChild("Items")
    local slot   = items  and items:FindFirstChild(slotName)
    if not slot then return nil end

    local descs
    pcall(function() descs = slot:GetDescendants() end)
    if not descs then return nil end
    for _, d in ipairs(descs) do
        local okN, name = pcall(function() return d.Name end)
        if okN and name == "Quantity" then
            local okT, txt = pcall(function() return d.Text end)
            if okT and type(txt) == "string" then
                return tonumber((txt:gsub(",", "")))
            end
        end
    end
    return nil
end

-- Reads "TIME TAKEN" off the Mission Completed rewards screen and
-- returns it as seconds. The exact UI path varies, so we walk the
-- Rewards subtree and look for any TextLabel whose text matches
-- the MM:SS pattern (the only stat in that screen formatted that
-- way). Returns nil if the rewards screen isn't up or no match
-- is found.
local function getRewardTimeTaken()
    local pg    = LocalPlayer:FindFirstChild("PlayerGui")
    local iface = pg    and pg:FindFirstChild("Interface")
    local rew   = iface and iface:FindFirstChild("Rewards")
    if not rew then return nil end

    local descs
    pcall(function() descs = rew:GetDescendants() end)
    if not descs then return nil end

    for _, d in ipairs(descs) do
        local okC, cn = pcall(function() return d.ClassName end)
        if okC and (cn == "TextLabel" or cn == "TextButton") then
            local okT, txt = pcall(function() return d.Text end)
            if okT and type(txt) == "string" then
                local mm, ss = txt:match("^%s*(%d+):(%d%d)%s*$")
                if mm and ss then
                    return tonumber(mm) * 60 + tonumber(ss)
                end
            end
        end
    end
    return nil
end

