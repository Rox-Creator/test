-- Auto Kill — self-contained farm using the drop+velocity pattern.
--   - Auto-engages a smaller (AutoKillHitboxSize) nape expansion so
--     the user doesn't need Hitbox Expander on separately.
--   - Each cycle TPs the player to (nape + AutoKillDropHeight) but
--     does NOT zero AssemblyLinearVelocity, so the downward velocity
--     from the previous drop carries over and the player slams
--     through the nape at increasing speed.
--   - Floor check exits the dwell early once the player crosses
--     (nape + AutoKillFloorBuffer), so they never reach nape level
--     (which would trigger nape-grab).
--   - Every AutoKillAnchorEvery cycles, the assembly's linear
--     velocity is INSTANTLY zeroed (no hold) so the player can't
--     run away with the speed buildup. Lower this knob if you're
--     overshooting; raise it for harder slams.
--   - Grab bailout: if the target titan has any "*grab*" attribute
--     set true (Left_nape_grab / Right_air_grab / etc.), the loop
--     TPs the player up high, zeroes velocity, and freezes for 0.5s.
task.spawn(function()
    -- Hold off until the player has had time to load into the map
    -- (see READY_DELAY at the top of the script).
    while tick() - SCRIPT_LOAD_AT < READY_DELAY do task.wait(0.5) end

    local prevActive = false
    local lastAttack = 0
    local activeTitan, activeNape = nil, nil
    local cycleCount = 0
    -- Blade-counter watchdog. If the HUD blade-set count doesn't
    -- decrement by at least 1 within BLADE_STUCK_TIMEOUT seconds we
    -- assume the kill loop is bugged out (slashes connecting but no
    -- damage registering, or a stuck animation, etc.) and tap R to
    -- swap blades — that almost always unsticks the state. Skipped
    -- entirely while Raid is active because the Eren fight involves
    -- long stretches without a set break.
    local lastBladeDecrement = tick()
    local prevBladeCount     = nil
    local BLADE_STUCK_TIMEOUT = 80    -- 1:20

    local function applyHitbox()
        local titansFolder = Workspace:FindFirstChild("Titans")
        if not titansFolder then return end
        local sizeVec = Vector3.new(AutoKillHitboxSize, AutoKillHitboxSize, AutoKillHitboxSize)
        for _, titan in ipairs(titansFolder:GetChildren()) do
            local nape = getNape(titan)
            if nape then
                local okAddr, addr = pcall(function() return nape.Address end)
                if okAddr and addr and not AutoKillOriginalSizes[addr] then
                    local okSz, sz = pcall(function() return nape.Size end)
                    if okSz and sz then AutoKillOriginalSizes[addr] = sz end
                end
                writePartSize(nape, sizeVec)
            end
        end
    end

    while GUI.Running do
        -- The kill engine runs whenever AutoKill OR Raid is on. They
        -- share the same slam pattern + tunables; Raid only swaps
        -- targeting / adds the Roar bailout.
        if Features.AutoKill or Features.Raid then
            -- Auto Refill is doing its TP → R → 5s wait. Stand down
            -- entirely (no TPs, no slashes) but DON'T restore titan
            -- sizes — we want them still expanded for when we come
            -- back.
            if RefillingNow then
                -- Hold the blade-decrement clock at "now" so the
                -- moment refill ends we don't immediately fire R
                -- (the refill itself made the count change).
                lastBladeDecrement = tick()
                prevBladeCount     = getBladeSets()
                task.wait(0.1)
            else
                prevActive = true

                applyHitbox()

            -- Tallest-first targeting: lock onto the biggest live
            -- titan and stay until it dies, then re-pick the next
            -- tallest. (Switching every cycle would thrash when
            -- two titans are equally tall.)
            if not (activeTitan and findHumanoid(activeTitan)) then
                if Features.Raid then
                    -- Eren Raid:
                    --   Phase 2 (Attack_Titan present in Titans
                    --     folder) — lock onto Eren, ignore trash.
                    --   Phase 1 (no Attack_Titan yet) — closest to
                    --     BigRock so titans don't reach Eren.
                    activeTitan, activeNape = getRaidTarget()
                else
                    activeTitan, activeNape = getTallestLiveTitan()
                end
                cycleCount = 0
            end

            -- Blade-counter watchdog. Track whether the HUD set
            -- count decreased recently; if it hasn't in 80s, we're
            -- almost certainly bugged out — tap R to swap blades and
            -- reset the clock. Skipped entirely while Raid is on
            -- (Eren fights have long no-break stretches).
            do
                local sets = getBladeSets()
                if sets then
                    if prevBladeCount and sets < prevBladeCount then
                        lastBladeDecrement = tick()
                    end
                    prevBladeCount = sets
                end
                if not Features.Raid
                   and tick() - lastBladeDecrement > BLADE_STUCK_TIMEOUT then
                    pcall(keypress,   0x52)
                    task.wait(0.08)
                    pcall(keyrelease, 0x52)
                    activeTitan, activeNape = nil, nil
                    cycleCount         = 0
                    lastBladeDecrement = tick()
                end
            end

            if activeTitan and activeNape then
                local hrp = getHRP()
                local okN, npos = pcall(function() return activeNape.Position end)
                if hrp and okN and npos then
                    -- Roar bailout (Eren Raid). Reads the State
                    -- attribute via GetAttribute (singular) and yeets
                    -- to nape + ROAR_HOVER_HEIGHT until State leaves
                    -- "Roar". Bypasses the standard slam pattern
                    -- entirely while the AOE is up.
                    if Features.Raid and isTitanRoaring(activeTitan) then
                        pcall(function()
                            hrp.CFrame = CFrame.new(npos.X, npos.Y + ROAR_HOVER_HEIGHT, npos.Z)
                        end)
                        pcall(function() hrp.AssemblyLinearVelocity = Vector3.zero end)
                        pcall(function() hrp.Velocity = Vector3.zero end)
                        task.wait(0.2)
                        cycleCount = 0
                    -- Grab bailout. If any "*grab*" attribute on the
                    -- target titan is set, TP up high, zero velocity,
                    -- and freeze 0.5s so we don't get held.
                    elseif isTitanGrabbing(activeTitan) then
                        pcall(function()
                            hrp.CFrame = CFrame.new(npos.X, npos.Y + AutoKillDropHeight + 60, npos.Z)
                        end)
                        pcall(function() hrp.AssemblyLinearVelocity = Vector3.zero end)
                        pcall(function() hrp.Velocity = Vector3.zero end)
                        task.wait(0.5)
                        cycleCount = 0
                    else
                        -- Standard cycle: TP up, leave velocity alone.
                        pcall(function()
                            hrp.CFrame = CFrame.new(npos.X, npos.Y + AutoKillDropHeight, npos.Z)
                        end)

                        cycleCount = cycleCount + 1

                        -- Periodic INSTANT velocity reset. Every Nth
                        -- cycle, zero the assembly's linear velocity
                        -- right after the TP-up — no hold loop. The
                        -- next cycle starts from a clean 0, so the
                        -- player only ever has at most N cycles' worth
                        -- of accumulated speed.
                        if cycleCount >= AutoKillAnchorEvery then
                            cycleCount = 0
                            pcall(function() hrp.AssemblyLinearVelocity = Vector3.zero end)
                            pcall(function() hrp.Velocity = Vector3.zero end)
                        end

                        if tick() - lastAttack >= KillCooldown then
                            performAttack()
                            lastAttack = tick()
                        end

                        -- Dwell with floor-check.
                        local floorY  = npos.Y + AutoKillFloorBuffer
                        local dwellEnd = tick() + AutoKillDropDwell
                        while tick() < dwellEnd do
                            local h2 = getHRP()
                            if not h2 then break end
                            local okP, p = pcall(function() return h2.Position end)
                            if okP and p and p.Y <= floorY then break end
                            task.wait(0.015)
                        end
                    end
                end
            else
                task.wait(0.3)
            end
            end   -- close: else of `if RefillingNow` (active, not refilling)
        else
            if prevActive then
                restoreAutoKillTitans()
                activeTitan, activeNape = nil, nil
                cycleCount = 0
                prevActive = false
            end
            task.wait(0.2)
        end
    end
end)

-- Auto Refill — when the blade-set HUD counter hits 0 and AutoKill
-- is on, TP to the nearest gas-tank Refill part, anchor onto it for
-- a few quick frames so a titan can't snatch us mid-refill, verify
-- we're actually within 5 studs of the tank, fire E once, and dump
-- back into the AutoKill flow as fast as possible. The whole cycle
-- takes ~1s instead of the old ~12s. Failures are still tracked: 3
-- consecutive blades-didn't-go-up triggers a 5-minute cooldown so
-- we don't spin forever (camera angle, tank clipped, etc).
local VK_REFILL_KEY      = 0x52   -- R (AOT:R refill prompt)
local REFILL_RANGE       = 5      -- studs — must be this close to count as on-tank
local REFILL_HEIGHT      = 5      -- studs above tank Y we anchor at
local REFILL_ANCHOR_TIME = 1.0    -- seconds of continuous re-anchoring on the tank
local REFILL_ANCHOR_GAP  = 0.10   -- gap between re-anchor pins
local REFILL_RSPAM_TIME  = 2.0    -- seconds to spam R while polling for success
local REFILL_POLL_STEP   = 0.05   -- how often we re-snapshot attrs during R-spam
local REFILL_POLL_TAIL   = 1.5    -- extra polling window after R-spam ends
local SAFE_SPOT_HEIGHT   = 2500   -- post-refill up-throw height
local SAFE_SPOT_DWELL    = 5.5    -- seconds of free-fall before AutoKill resumes

task.spawn(function()
    -- Same load-in hold-off as AutoKill — refill is just as
    -- disruptive if it fires before the character is controllable.
    while tick() - SCRIPT_LOAD_AT < READY_DELAY do task.wait(0.5) end
    while GUI.Running do
        if Features.AutoRefill
           and (Features.AutoKill or Features.Raid)
           and not RefillingNow
           and tick() >= refillCooldownUntil then
            local sets = getBladeSets()
            if sets == 0 then
                local refill = getNearestRefill()
                if refill then
                    RefillingNow = true

                    local okP, rPos = pcall(function() return refill.Position end)
                    if okP and rPos then
                        -- Snapshot every numeric Player attribute up
                        -- front. AOT:R's refill-canister counter is
                        -- a Player attribute that drops the instant
                        -- R is accepted — that's our success signal
                        -- (HUD blade-sets text lags behind).
                        local beforeAttrs = snapshotPlayerNumericAttrs()

                        local function anchor()
                            local h = getHRP()
                            if not h then return end
                            pcall(function()
                                h.CFrame = CFrame.new(rPos.X, rPos.Y + REFILL_HEIGHT, rPos.Z)
                            end)
                            pcall(function() h.AssemblyLinearVelocity = Vector3.zero end)
                            pcall(function() h.Velocity                = Vector3.zero end)
                        end

                        -- Continuous re-anchor for 2 full seconds.
                        -- Re-pinning every 100ms (~20 pins) keeps the
                        -- player parked on the tank even when Auto
                        -- Booster's space-spam is pushing upward and
                        -- titans are nudging us mid-physics-step.
                        local anchorEnd = tick() + REFILL_ANCHOR_TIME
                        while tick() < anchorEnd do
                            anchor()
                            task.wait(REFILL_ANCHOR_GAP)
                        end

                        -- Verify we're actually on the tank.
                        local h = getHRP()
                        local onTank = false
                        if h then
                            local okPP, pPos = pcall(function() return h.Position end)
                            if okPP and pPos then
                                local dx = pPos.X - rPos.X
                                local dy = pPos.Y - rPos.Y
                                local dz = pPos.Z - rPos.Z
                                if dx*dx + dy*dy + dz*dz <= REFILL_RANGE * REFILL_RANGE then
                                    onTank = true
                                end
                            end
                        end

                        local refillSucceeded = false

                        if onTank then
                            -- Spam R for 2s while polling attrs in
                            -- the same loop. Toggling press/release
                            -- every poll step gives ~10 taps/sec —
                            -- way more reliable than a single tap
                            -- when the prompt's accept window is
                            -- short or the input system is busy.
                            local spamEnd   = tick() + REFILL_RSPAM_TIME
                            local pollUntil = tick() + REFILL_RSPAM_TIME + REFILL_POLL_TAIL
                            local rDown     = false
                            while tick() < pollUntil do
                                if tick() < spamEnd then
                                    if rDown then
                                        pcall(keyrelease, VK_REFILL_KEY)
                                        rDown = false
                                    else
                                        pcall(keypress, VK_REFILL_KEY)
                                        rDown = true
                                    end
                                elseif rDown then
                                    pcall(keyrelease, VK_REFILL_KEY)
                                    rDown = false
                                end

                                local afterAttrs = snapshotPlayerNumericAttrs()
                                for k, v in pairs(beforeAttrs) do
                                    local a = afterAttrs[k]
                                    if a and a < v then
                                        refillSucceeded = true
                                        break
                                    end
                                end
                                if refillSucceeded then break end
                                task.wait(REFILL_POLL_STEP)
                            end
                            if rDown then pcall(keyrelease, VK_REFILL_KEY) end

                            -- On success, throw the player +2500 studs
                            -- up ONCE and let gravity drop them. Auto
                            -- Kill stays paused (RefillingNow=true)
                            -- for the whole free-fall, so nothing can
                            -- grab them on the way down. Cleanest way
                            -- to clear the area without re-anchoring.
                            if refillSucceeded then
                                local h2 = getHRP()
                                if h2 then
                                    local okPP, pPos = pcall(function() return h2.Position end)
                                    if okPP and pPos then
                                        pcall(function()
                                            h2.CFrame = CFrame.new(pPos.X,
                                                pPos.Y + SAFE_SPOT_HEIGHT, pPos.Z)
                                        end)
                                        pcall(function() h2.AssemblyLinearVelocity = Vector3.zero end)
                                        pcall(function() h2.Velocity                = Vector3.zero end)
                                        task.wait(SAFE_SPOT_DWELL)
                                    end
                                end
                            end
                        end

                        if refillSucceeded then
                            refillFailures      = 0
                            refillCooldownUntil = 0   -- resume now
                        else
                            refillFailures = refillFailures + 1
                            if refillFailures >= 3 then
                                refillCooldownUntil = tick() + 300   -- 5 min
                                refillFailures = 0
                                pcall(notify,
                                    "Auto Refill failed 3 times — pausing 5 minutes",
                                    "AOT:R", 4)
                                sendRefillFailed()
                            else
                                -- Short backoff so we don't ram the
                                -- tank again next tick if this attempt
                                -- whiffed (e.g. nudged off mid-press).
                                refillCooldownUntil = tick() + 2
                            end
                        end
                    end

                    RefillingNow = false
                end
            end
        end
        task.wait(0.5)
    end
end)

