local rainbowSegs = {}

local function buildRainbowBorder()
    rainbowSegs = {}
    local wx, wy = Config.WinX, Config.WinY
    local ww, wh = Config.WinW, Config.WinH
    local thickness = 2
    local nTop, nRight, nBot, nLeft = 36, 24, 36, 24
    local total = nTop + nRight + nBot + nLeft

    local idx = 0
    local function addSeg(x, y, w, h)
        local s = Drawing.new("Square")
        s.Position = Vector2.new(x, y); s.Size = Vector2.new(w, h)
        s.Color = Color3.fromHSV(idx / total, 0.9, 1)
        s.Filled = true; s.Visible = false; s.ZIndex = 20
        table.insert(GUI.Elements, s)
        table.insert(rainbowSegs, { sq = s, perim = idx / total })
        idx = idx + 1
    end

    local segW = ww / nTop
    for i = 1, nTop do addSeg(wx + (i - 1) * segW, wy, segW + 0.5, thickness) end
    local segH = wh / nRight
    for i = 1, nRight do addSeg(wx + ww - thickness, wy + (i - 1) * segH, thickness, segH + 0.5) end
    for i = 1, nBot do addSeg(wx + ww - i * segW, wy + wh - thickness, segW + 0.5, thickness) end
    for i = 1, nLeft do addSeg(wx, wy + wh - i * segH, thickness, segH + 0.5) end
end

local SNAKE_FRAC, SNAKE_SPEED = 0.20, 0.16
local SNAKE_HEAD_COLOR = Color3.fromRGB(140, 190, 255)
local SNAKE_TAIL_COLOR = Color3.fromRGB(30, 45, 80)

task.spawn(function()
    while GUI.Running do
        -- 20Hz instead of 40Hz. With 120 segments and Luraph's per-call
        -- overhead, halving the tick rate roughly halves the constant
        -- CPU cost without making the snake noticeably less smooth.
        task.wait(0.05)
        if GUI.Visible and not GUI.Minimized and type(rainbowSegs) == "table" and #rainbowSegs > 0 then
            local t = tick()
            local headPos = (t * SNAKE_SPEED) % 1
            for _, seg in ipairs(rainbowSegs) do
                pcall(function()
                    local d = (headPos - seg.perim) % 1
                    if d <= SNAKE_FRAC then
                        local snakeT = d / SNAKE_FRAC
                        local fade = 1 - snakeT
                        local et = fade * fade
                        seg.sq.Color = lerpColor(SNAKE_TAIL_COLOR, SNAKE_HEAD_COLOR, et)
                        seg.sq.Visible = true
                    elseif seg.sq.Visible then
                        seg.sq.Visible = false
                    end
                end)
            end
        end
    end
end)

