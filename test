-- Bind button (rectangle pill that displays a key name; click to listen).
local function DrawBindButton(bx, by, keyVK, isListening, zbase, onClick)
    local btnW, btnH = 80, 26

    -- Capture the base color BEFORE assigning to the Drawing
    -- instance. Reading it back off the instance after assignment
    -- (e.g. `bg.Color`) is what some obfuscators (Luraph, Moonveil)
    -- mangle into nil — then the hover handler crashes with
    -- "attempt to index nil with 'R'" inside `lighten`.
    local baseColor = isListening and Colors.AccentRed or Colors.ToggleOff
    local bg = Drawing.new("Square")
    bg.Position = Vector2.new(bx, by); bg.Size = Vector2.new(btnW, btnH)
    bg.Color = baseColor
    bg.Filled = true; bg.Corner = 4
    bg.Visible = true; bg.ZIndex = zbase + 3
    table.insert(GUI.ContentElements, bg)

    -- Position / size match Bridger.lua's bind button so the text
    -- visually centers inside the 26-tall pill.
    local txt = Drawing.new("Text")
    txt.Position = Vector2.new(bx + btnW / 2, by + 11)
    txt.Text = isListening and "..." or getKeyName(keyVK)
    txt.Color = Colors.TextPrimary
    txt.Size = 14; txt.Font = Drawing.Fonts.SystemBold
    txt.Center = true; txt.Outline = false
    txt.Visible = true; txt.ZIndex = zbase + 5
    table.insert(GUI.ContentElements, txt)

    table.insert(GUI.Clickables, {
        x = bx, y = by, w = btnW, h = btnH,
        hover = { el = bg, base = baseColor },
        onClick = onClick,
    })
end

