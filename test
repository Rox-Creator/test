-- ============================================================

local function clamp01(v)
    if v < 0 then return 0 end
    if v > 1 then return 1 end
    return v
end

local function lerpColor(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

local function lighten(c, amount)
    -- Guard against nil base colors. Some obfuscators mangle the
    -- `Drawing.Color` re-read in hover-table construction so the
    -- base ends up nil; without this the hover loop would crash
    -- inside `c.R`. Returning white as a fallback keeps the GUI
    -- working even if a hover state can't tint correctly.
    if not c then return Color3.new(1, 1, 1) end
    return Color3.new(clamp01(c.R + amount), clamp01(c.G + amount), clamp01(c.B + amount))
end

local function IsInside(mx, my, x, y, w, h)
    return mx >= x and mx <= x + w and my >= y and my <= y + h
end

local function splitCols(cardX, cardW)
    local colW = (cardW - Config.ColGap) / 2
    return cardX, cardX + colW + Config.ColGap, colW
end

-- Animation token used to invalidate in-flight tweens on drag / rebuild
local function newAnimToken()
