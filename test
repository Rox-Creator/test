-- Press effect (gen-checked so Luraph doesn't log dead-element accesses).
local function pressEffect(el)
    if not el then return end
    local gen = GUI.ContentGen
    task.spawn(function()
        if GUI.ContentGen ~= gen then return end
        local okP, pos = pcall(function() return el.Position end)
        local okS, sz  = pcall(function() return el.Size end)
        if not (okP and pos and okS and sz) then return end
        if type(pos) ~= "userdata" and type(pos) ~= "table" then return end
        if GUI.ContentGen ~= gen then return end
        pcall(function()
            el.Position = Vector2.new(pos.X + 1, pos.Y + 1)
            el.Size     = Vector2.new(sz.X - 2, sz.Y - 2)
        end)
        task.wait(0.07)
        if GUI.ContentGen ~= gen then return end
        pcall(function() el.Position = pos; el.Size = sz end)
    end)
end

local function animateToggle(knob, bg, fromX, toX, fromColor, toColor, onDone)
    local gen = GUI.ContentGen
    task.spawn(function()
        local steps, stepTime = 8, 0.018
        for i = 1, steps do
            if GUI.ContentGen ~= gen then break end
            local t = i / steps
            local et = 1 - (1 - t) ^ 3
            pcall(function()
                local okPos = pcall(function() return knob.Position end)
                if not okPos then return end
                knob.Position = Vector2.new(fromX + (toX - fromX) * et, knob.Position.Y)
                bg.Color      = lerpColor(fromColor, toColor, et)
            end)
            task.wait(stepTime)
        end
        if onDone then pcall(onDone) end
    end)
end

