-- Format integers with comma thousands separators ("1234567" →
-- "1,234,567"). Declared up here so the webhook senders below can
-- use it; FormatUptime / the original commaFmt callsite further
-- down still works with this definition (single source of truth).
local function commaFmt(n)
    n = math.floor(tonumber(n) or 0)
    local s = tostring(n)
    while true do
        local replaced
        s, replaced = s:gsub("^(-?%d+)(%d%d%d)", "%1,%2")
        if replaced == 0 then break end
    end
    return s
end

-- "01:49" style for the per-mission timer.
local function fmtMMSS(seconds)
    seconds = math.floor(tonumber(seconds) or 0)
    return string.format("%02d:%02d", math.floor(seconds / 60), seconds % 60)
end

-- "2m 0s" / "1h 23m" style for session uptime.
local function fmtHumanDuration(seconds)
    seconds = math.floor(tonumber(seconds) or 0)
    if seconds < 60 then return seconds .. "s" end
    local m = math.floor(seconds / 60)
    local s = seconds % 60
    if m < 60 then return string.format("%dm %ds", m, s) end
    local h = math.floor(m / 60)
    m = m % 60
    return string.format("%dh %dm", h, m)
end

-- ----- Discord webhook ---------------------------------------

-- Pulls the URL from the `Webhook_URL` global the user sets above
-- the loadstring call. Validates it looks like a real Discord
-- webhook URL — anything else is dropped.
local function loadWebhookUrl()
    if type(Webhook_URL) ~= "string" then return end
    -- Obfuscator-safe form: chained colon-method calls on a global
    -- read get mangled by some obfuscators (Moonveil), so go through
    -- string.gsub directly instead.
    local trimmed = string.gsub(Webhook_URL, "^[%s]+", "")
    trimmed       = string.gsub(trimmed,     "[%s]+$", "")
    if trimmed:match("^https://discord%.com/api/webhooks/") or
       trimmed:match("^https://discordapp%.com/api/webhooks/") then
        WEBHOOK_URL = trimmed
    end
end

-- POSTs a JSON-encoded payload to the webhook. Matcha exposes
-- `game:HttpPost(url, body, contentType)` (and the lowercase
-- `httppost` alias). The executor-style `request` / `syn.request` /
-- `HttpService:PostAsync` calls are NOT available in Matcha — those
-- silently fail under pcall, which is why earlier versions of this
-- function appeared to no-op even when WEBHOOK_URL was set.
local function sendWebhookRaw(payload)
    if WEBHOOK_URL == "" then return end
    local body = HttpService:JSONEncode(payload)
    task.spawn(function()
        local fired = false
        local function try(fn)
            if fired then return end
            local ok, err = pcall(fn)
            if ok then fired = true
            else print("[AOT:R webhook] " .. tostring(err)) end
        end
        try(function() return game:HttpPost(WEBHOOK_URL, body, "application/json") end)
        try(function() return httppost(WEBHOOK_URL, body, "application/json") end)
    end)
end

local function getPlayerName()
    local ok, name = pcall(function() return LocalPlayer.Name end)
    if ok and type(name) == "string" and name ~= "" then return name end
    return "Unknown"
end

-- Reads Workspace's own attributes for the current mission. AOT:R
-- exposes Type ("Raids", etc.) and Difficulty ("Aberrant", "Hard"
-- …) directly on the Workspace instance. Returns "Type -
-- Difficulty" or whichever single one is readable, or nil if both
-- are missing. Used in the mission-completed webhook header.
local function getMissionInfo()
    local ws = Workspace
    if not ws then return nil end
    local okT, t = pcall(function() return ws:GetAttribute("Type") end)
    local okD, d = pcall(function() return ws:GetAttribute("Difficulty") end)
    local typ = (okT and type(t) == "string" and t ~= "") and t or nil
    local dif = (okD and type(d) == "string" and d ~= "") and d or nil
    if typ and dif then return typ .. " - " .. dif end
    return typ or dif
end

-- AOT:R stores per-player stats (Streak, Level, etc.) as attributes
-- on the Player instance — i.e. game.Players.zWaleed = LocalPlayer.
-- The singular GetAttribute(name) call works on Player objects
-- (unlike on workspace Models, where Matcha's GetAttributes returns
-- only an array of names and GetAttribute returns nil).
local function getPlayerAttr(name)
    local ok, v = pcall(function() return LocalPlayer:GetAttribute(name) end)
    if ok then
        local n = tonumber(v)
        if n then return n end
    end
    return 0
end

local function getKillstreak() return getPlayerAttr("Streak") end
local function getLevel()      return getPlayerAttr("Level")  end

-- Snapshot every numeric attribute on LocalPlayer as a name→number
-- map. Used by Auto Refill to detect a successful refill: AOT:R
-- decrements a refill-canister attribute by 1 when R is accepted at
-- a gas tank, so any numeric attr that drops between before/after
-- snapshots = refill landed.
--
-- Matcha is inconsistent about GetAttributes shape across instance
-- classes — on Player it MIGHT return name=value pairs OR an array
-- of names. Handle both: if we see a numeric key with string value,
-- treat it as a name and fetch the value via the singular call
-- (which we know works on Player).
local function snapshotPlayerNumericAttrs()
    local snap = {}
    local ok, attrs = pcall(function() return LocalPlayer:GetAttributes() end)
    if ok and type(attrs) == "table" then
        for k, v in pairs(attrs) do
            if type(k) == "number" and type(v) == "string" then
                local ok2, vv = pcall(function() return LocalPlayer:GetAttribute(v) end)
                if ok2 then
                    local n = tonumber(vv)
                    if n then snap[v] = n end
                end
            else
                local n = tonumber(v)
                if n then snap[tostring(k)] = n end
            end
        end
    end
    return snap
end


-- Build a Discord embed with the script's blue accent. `fields` is
-- a list of {name, value, inline=true} tuples. inline defaults to
-- true unless explicitly set to false.
local function buildEmbed(title, color, fields)
    local f = {}
    for _, fld in ipairs(fields or {}) do
        table.insert(f, {
            name   = tostring(fld[1]),
            value  = tostring(fld[2]),
            inline = fld[3] ~= false,
        })
    end
    return {
        embeds = {{
            title  = title,
            color  = color,
            fields = f,
            footer = { text = "Rox's Menu | AOT:R" },
        }},
    }
end

-- Zero-width space (U+200B). Used as the name/value of an inline
-- "spacer" field — drops into the current row as a blank 3rd column
-- to force the next inline field onto a fresh row. Inline (not
-- non-inline) because a non-inline ZWSP field renders as TWO blank
-- lines (name + value), giving an awkward double gap; inline lets
-- it ride along the current row and the gap to the next row stays
-- at Discord's natural single-row spacing.
local ZWSP = "\226\128\139"
local SPACER = { ZWSP, ZWSP, true }

-- Appended to inline-field values to add one line of vertical
-- padding below them. Discord aligns inline fields by their top
-- edge and the row's bottom is at the tallest field's bottom — so
-- if every inline value ends with a newline + ZWSP, every row is
-- 2 value-lines tall and the next row starts a clean line below.
-- Cleanest way to get a consistent 1-line gap between every row
-- without inserting extra full-width spacer fields.
local PAD = "\n" .. ZWSP

-- Convenience colors (matches the script's own palette).
local EMBED_OK     = 0x5F91E6   -- accent blue (default mission completed)
local EMBED_WARN   = 0xFFC83C   -- amber (stuck mission)
local EMBED_BAD    = 0xFF6464   -- red (refill failed / unloaded)
local EMBED_GOOD   = 0x50DC8C   -- green (script loaded)

local function sendMissionCompleted(runKills, expGain, goldGain, timeTaken)
    -- Each block is gated on its own WebhookOptions toggle, so
    -- users can pare the embed down to just what they care about.
    local fields = {}

    -- Header: Mission Info (Type - Difficulty) above everything.
    if WebhookOptions.SendMissionInfo then
        local info = getMissionInfo()
        if info then
            table.insert(fields, { "Mission", info, false })
        end
    end

    -- Identity / progression row (Player, Killstreak, Level). Each
    -- toggle is independent — if you only enable Player, you get a
    -- single inline cell (no row break needed).
    do
        local identity = {}
        if WebhookOptions.SendPlayerName then
            table.insert(identity, { "Player",     getPlayerName(),           true })
        end
        if WebhookOptions.SendKillstreak then
            table.insert(identity, { "Killstreak", tostring(getKillstreak()), true })
        end
        if WebhookOptions.SendLevel then
            table.insert(identity, { "Level",      tostring(getLevel()),      true })
        end
        if #identity > 0 then
            -- Pad the last cell so the next group starts on a fresh row.
            local last = identity[#identity]
            last[2] = last[2] .. PAD
            for _, f in ipairs(identity) do table.insert(fields, f) end
        end
    end

    -- Mission outcome row.
    if WebhookOptions.SendStats then
        table.insert(fields, { "Titans Killed", tostring(runKills or 0),         true })
        table.insert(fields, { "Time Taken",    fmtMMSS(timeTaken or 0) .. PAD,  true })
        table.insert(fields, SPACER)
    end

    -- Rewards row.
    if WebhookOptions.SendRewards then
        table.insert(fields, { "Gold Gained", "+" .. commaFmt(goldGain or 0),          true })
        table.insert(fields, { "EXP Gained",  ("+" .. commaFmt(expGain  or 0)) .. PAD, true })
    end

    -- Session totals (full width).
    if WebhookOptions.SendSession then
        table.insert(fields, { "Session Overall",
            string.format("EXP: %s  •  Gold: %s  •  Kills: %s\nRetries: %s  •  Uptime: %s",
                commaFmt(LifetimeStats.exp),
                commaFmt(LifetimeStats.gold),
                commaFmt(LifetimeStats.titansKilled),
                commaFmt(LifetimeStats.retries),
                fmtHumanDuration(LifetimeStats.uptime)),
            false })
    end

    if #fields == 0 then return end   -- everything off — skip entirely
    sendWebhookRaw(buildEmbed("🎯 Mission Completed!", EMBED_OK, fields))
end

local function sendStuckMission()
