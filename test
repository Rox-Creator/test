-- Auto Booster — while the player is positioned ABOVE a live titan
-- (i.e. mid-air on top of one), tap Space repeatedly. AOT:R's
-- "double-Space" gives a dash in the camera's look direction; chain
-- presses build velocity for harder slam damage on tankier titans.
-- Strict on/off: only fires when (a) feature is enabled AND (b) the
-- player is currently above a titan within a small XZ radius and
-- some Y range above its nape. Prevents the bind from firing during
-- normal traversal or while on the ground.
local VK_SPACE = 0x20

task.spawn(function()
    while tick() - SCRIPT_LOAD_AT < READY_DELAY do task.wait(0.5) end

    -- Tunables for the "am I on a titan?" check.
    local AB_XZ_RADIUS = 25     -- studs of XZ slack from nape position
    local AB_MIN_Y     = 2      -- player must be at least this many studs above nape
    local AB_MAX_Y     = 120    -- ...and no more than this far above (so falling-from-the-sky doesn't count)
    local AB_TAP_GAP   = 0.10   -- seconds between Space taps

    while GUI.Running do
        if Features.AutoBooster then
            local hrp = getHRP()
            local titansFolder = Workspace:FindFirstChild("Titans")
            local onTitan = false
            if hrp and titansFolder then
                local okPP, pPos = pcall(function() return hrp.Position end)
                if okPP and pPos then
                    for _, titan in ipairs(titansFolder:GetChildren()) do
                        if findHumanoid(titan) then
                            local nape = getNape(titan)
                            if nape then
                                local okN, npos = pcall(function() return nape.Position end)
                                if okN and npos then
                                    local dx = pPos.X - npos.X
                                    local dz = pPos.Z - npos.Z
                                    local dy = pPos.Y - npos.Y
                                    if dx*dx + dz*dz <= AB_XZ_RADIUS * AB_XZ_RADIUS
                                       and dy >= AB_MIN_Y and dy <= AB_MAX_Y then
                                        onTitan = true
                                        break
                                    end
                                end
                            end
                        end
                    end
                end
            end

            if onTitan then
                pcall(keypress,   VK_SPACE)
                task.wait(0.04)
                pcall(keyrelease, VK_SPACE)
                task.wait(AB_TAP_GAP)
            else
                task.wait(0.15)
            end
        else
            task.wait(0.3)
        end
    end
end)

-- Auto Retry — when "Mission Completed" comes up, drive Roblox's
-- built-in GUI navigation to focus and activate the RETRY button.
--
-- Tried-and-failed mouse approaches (don't bring them back):
--   • mousemoverel — AOT:R's mouse-look handler eats the deltas;
--     the OS cursor never moves
--   • mousemoveabs raw pixels — flies to the screen corner
--   • mousemoveabs normalized 0..65535 — non-deterministic, often
--     a no-op, sometimes lands at (0,0)
--
-- Keyboard nav is the only reliable path here:
--   \         engages GUI nav (focus lands on the Leave button)
--   D ×2      steps focus right: Leave → Modify → Retry
--   Enter     activates the focused button
local VK_BACKSLASH = 0xDC   -- "\" / VK_OEM_5
local VK_D         = 0x44
local VK_ENTER     = 0x0D

local function retryButtonInstance()
    local pg     = LocalPlayer:FindFirstChild("PlayerGui")
    local iface  = pg     and pg:FindFirstChild("Interface")
    local rew    = iface  and iface:FindFirstChild("Rewards")
    local mainA  = rew    and rew:FindFirstChild("Main")
    local info   = mainA  and mainA:FindFirstChild("Info")
    local mainB  = info   and info:FindFirstChild("Main")
    local btns   = mainB  and mainB:FindFirstChild("Buttons")
    return btns and btns:FindFirstChild("Retry")
end

task.spawn(function()
    local lastFire           = 0
    local lastSawLiveTitan   = 0      -- tick() at which we last saw a Humanoid'd titan
    local firedThisSession   = false  -- prevents re-firing while rewards is still up

    local function retryButtonExists()
        return retryButtonInstance() ~= nil
    end

    local function tap(vk)
        pcall(keypress, vk)
        task.wait(0.08)
        pcall(keyrelease, vk)
    end

    local function anyLiveTitan()
        local titans = Workspace:FindFirstChild("Titans")
        if not titans then return false end
        for _, t in ipairs(titans:GetChildren()) do
            if findHumanoid(t) then return true end
        end
        return false
    end

    while GUI.Running do
        do
            local hasTitan = anyLiveTitan()
            if hasTitan then lastSawLiveTitan = tick() end

            -- Rewards-screen detection. We use getRewardTimeTaken()
            -- as the "is the post-mission screen actually showing?"
            -- signal because the TIME TAKEN label only renders with
            -- a MM:SS value on the mission-completed UI — it stays
            -- nil during gameplay AND during cutscenes (cutscenes
            -- have no titans, which used to false-trigger us).
            -- Cleaner than the old "no titans for 3-30s" timer.
            local rewardsShowing = getRewardTimeTaken() ~= nil

            -- Re-arm whenever the rewards screen isn't up. After we
            -- fire a retry the screen disappears (sub-place teleport)
            -- and `firedThisSession` resets here, so the next
            -- mission's rewards screen can fire again.
            if not rewardsShowing then firedThisSession = false end

            -- Two firing paths:
            --   A. NORMAL — rewards screen is actually displayed
            --   B. STUCK MISSION — AutoKill is on, titan models
            --      still exist, but no kill in 3+ minutes. The
            --      mission's frozen up. Force a retry.
            local cleanEnd = rewardsShowing
            local stuckMission = (Features.AutoKill or Features.Raid)
                              and (tick() - lastKillAt) > 180
                              and getTitanCount() > 0
            if (cleanEnd or stuckMission)
               and (not firedThisSession)
               and (tick() - lastFire > 4.0)
               and retryButtonExists() then
                firedThisSession = true
                lastFire = tick()
                if stuckMission and not cleanEnd then
                    pcall(notify,
                        "Stuck mission detected — forcing retry",
                        "AOT:R", 3)
                    sendStuckMission()
                end

                -- Re-inject after the sub-place transition. AOT:R's
                -- retry teleports to a new sub-place, which spawns a
                -- fresh Lua VM and kills our coroutines. Matcha's
                -- autoexec only fires on the first game join, so it
                -- won't re-run on sub-place hops. queue_on_teleport
                -- queues code to run once the next teleport completes
                -- — we point it at the on-disk copy of this script so
                -- it reloads itself on the new map.
                --
                -- One-time setup the user has to do:
                --   1. Save AOTR.lua to c:\matcha\workspace\AOTR\AOTR.lua
                --   2. Put this in Matcha's auto-execute slot (for the
                --      initial game join):
                --        pcall(function()
                --            loadstring(readfile("AOTR/AOTR.lua"))()
                --        end)
                pcall(function()
                    if queue_on_teleport then
                        queue_on_teleport([[
                            pcall(function()
                                if isfile and isfile("AOTR/AOTR.lua") then
                                    loadstring(readfile("AOTR/AOTR.lua"))()
                                end
                            end)
                        ]])
                    end
                end)

                -- Capture rewards BEFORE we start the retry sequence,
                -- while the Rewards screen is still visible. EXP is
                -- always slot 1_1, Gold is always slot 1_2 in AOT:R.
                local expGain  = getRewardItemQuantity("1_1") or 0
                local goldGain = getRewardItemQuantity("1_2") or 0
                LifetimeStats.exp     = LifetimeStats.exp     + expGain
                LifetimeStats.gold    = LifetimeStats.gold    + goldGain
                LifetimeStats.retries = LifetimeStats.retries + 1
                LifetimeDirty = true

                -- Send the mission-completed embed only on the clean
                -- end path (cleanEnd). The stuck-mission embed has
                -- already been sent above and these run-stats won't
                -- be meaningful in that case. Read Time Taken from
                -- the rewards UI itself — the in-game timer is the
                -- truth, not anything we'd compute here.
                local timeTaken = getRewardTimeTaken() or 0
                if cleanEnd then
                    sendMissionCompleted(Stats.RunKills, expGain, goldGain, timeTaken)
                end
                Stats.RunKills = 0      -- arm for next mission either way

                -- \ → D D → Enter, with 0.3s gaps so each press
                -- registers before the next.
                tap(VK_BACKSLASH)
                task.wait(0.3)
                tap(VK_D)
                task.wait(0.3)
                tap(VK_D)
                task.wait(0.3)
                tap(VK_ENTER)
            end
        end
        task.wait(0.5)
    end
end)

-- Lifetime stats: accumulate uptime in 5s ticks while a kill mode is
-- active, and flush to disk every 30s (or sooner if a counter event
-- has marked the stats dirty). Uses a separate cadence from the
-- counter increments so we batch disk writes.
task.spawn(function()
    local lastSaveAt = tick()
    while GUI.Running do
        task.wait(5)
        if Features.AutoKill or Features.Raid then
            LifetimeStats.uptime = LifetimeStats.uptime + 5
            LifetimeDirty = true
        end
        if LifetimeDirty and tick() - lastSaveAt >= 30 then
            saveLifetimeStats()
            lastSaveAt = tick()
        end
    end
end)

-- Kill counter — watches titan alive→dead transitions
task.spawn(function()
    local lastTitanState = {}
    while GUI.Running do
        task.wait(0.5)
        if Features.AutoKill or Features.Raid then
            local folder = Workspace:FindFirstChild("Titans")
            if folder then
                local seen = {}
                for _, titan in ipairs(folder:GetChildren()) do
                    local okA, addr = pcall(function() return titan.Address end)
                    if okA and addr then
                        seen[addr] = true
                        local alive = findHumanoid(titan) ~= nil
                        if lastTitanState[addr] == true and not alive then
                            Stats.TitansKilled = Stats.TitansKilled + 1
                            Stats.RunKills     = Stats.RunKills + 1
                            LifetimeStats.titansKilled = LifetimeStats.titansKilled + 1
                            LifetimeDirty = true
                            lastKillAt = tick()
                        end
                        lastTitanState[addr] = alive
                    end
                end
                for addr in pairs(lastTitanState) do
                    if not seen[addr] then lastTitanState[addr] = nil end
                end
            end
        end
    end
end)

