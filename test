local function getViewportSize()
    local cam = Workspace and Workspace.CurrentCamera
    if cam then
        local ok, vp = pcall(function() return cam.ViewportSize end)
        if ok and vp and vp.X and vp.X > 0 then return vp.X, vp.Y end
    end
    return 1920, 1080
end

