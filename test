-- AOT:R Standalone — no GUI, runs every farm in the background.
-- Edit the SETTINGS block below to tune the slam pattern and timings.
--
-- Hotkey: End to unload.

local Players     = game:GetService("Players")
local Workspace   = game:GetService("Workspace")
local HttpService = game:GetService("HttpService")

-- Autoexec fires before the player joins, so Players.LocalPlayer is
-- nil for the first 1-3 seconds. Block the script here until it
-- exists, otherwise every helper that does `LocalPlayer:FindFirstChild`
-- crashes with "attempt to index nil".
local LocalPlayer = Players.LocalPlayer
while not LocalPlayer do
    task.wait(0.2)
    LocalPlayer = Players.LocalPlayer
end

-- Same for PlayerGui — exists shortly after LocalPlayer.
while not LocalPlayer:FindFirstChild("PlayerGui") do
    task.wait(0.2)
end

local OffsetsJSON = game:HttpGet("https://offsets.ntgetwritewatch.workers.dev/offsets.json")
local Offsets     = HttpService:JSONDecode(OffsetsJSON)

-- ============================================================
-- SETTINGS — tweak these to taste
-- ============================================================

-- Auto Kill slam pattern (matches the Tuning sliders from AOTR.lua)
local HitboxSize    = 150     -- nape hitbox cube size (studs)
local DropHeight    = 85      -- studs above nape we snap each cycle
local DropDwell     = 0.15    -- max free-fall seconds before TP'ing back up
local FloorBuffer   = 60      -- exit dwell once player crosses nape.Y + this
local AnchorEvery   = 8       -- cycles between INSTANT velocity resets
local KillCooldown  = 0.10    -- seconds between slashes

-- Boot delay — same 8s warmup AOTR.lua uses, so the player isn't TPed
-- onto a titan before they've finished loading the map.
local ReadyDelay    = 8

-- Auto Booster
local BoostXZRadius = 25      -- studs of XZ slack from nape position
local BoostMinY     = 2       -- player must be at least this many studs above nape
local BoostMaxY     = 120     -- ...and no more than this far above
local BoostTapGap   = 0.10    -- seconds between Space taps

-- Auto Refill
local RefillRange       = 5     -- XZ studs — must be this close to count as on-tank
local RefillHeight      = 5     -- studs above tank Y we anchor at
local RefillAnchorTime  = 1.0   -- seconds of continuous re-anchoring on the tank
local RefillAnchorGap   = 0.10  -- gap between re-anchor pins
local RefillRSpamTime   = 2.0   -- seconds to spam R while polling for success
local RefillPollStep    = 0.05  -- how often we re-snapshot attrs during R-spam
local RefillPollTail    = 1.5   -- extra polling window after R-spam ends
local SafeSpotHeight    = 400   -- post-refill up-throw height
local SafeSpotDwell     = 2.5   -- seconds of free-fall before AutoKill resumes

-- Watchdogs
local BladeStuckTimeout = 80    -- seconds — taps R if no blade decrement this long
local StuckMissionAfter = 180   -- seconds — force retry if no kill in this long

-- The HUD reads "0" when 3 of the player's 4 blade SETS have been
-- spent, but the 4th set is still equipped and usable. Wait this
-- long after blades first read 0 before triggering refill, so the
-- last set actually gets used first.
local BladesZeroDelay = 8

-- Re-injection path. Set this to wherever you save THIS file. After
-- a sub-place retry, queue_on_teleport reloads from disk so the
-- script keeps running on the new map.
local SelfPath = "AOTR/AOTRBare.lua"

-- ============================================================
-- INTERNAL STATE
-- ============================================================

local Running             = true
local SCRIPT_LOAD_AT      = tick()
local RefillingNow        = false
local lastKillAt          = tick()
local refillFailures      = 0
local refillCooldownUntil = 0
local OriginalSizes       = {}

-- ============================================================
-- HELPERS
-- ============================================================

local function writePartSize(part, sizeVec)
    pcall(function() part.Size = sizeVec end)
    local okAddr, addr = pcall(function() return part.Address end)
    if not (okAddr and addr) then return end
    local okPrim, prim = pcall(memory_read, "uintptr_t", addr + Offsets.Primitive)
    if not (okPrim and prim and prim ~= 0) then return end
    pcall(memory_write, "float", prim + Offsets.PartSize + 0, sizeVec.X)
    pcall(memory_write, "float", prim + Offsets.PartSize + 4, sizeVec.Y)
    pcall(memory_write, "float", prim + Offsets.PartSize + 8, sizeVec.Z)
end

local function getNape(titan)
    local hitboxes = titan:FindFirstChild("Hitboxes")
    if not hitboxes then return nil end
    local hit = hitboxes:FindFirstChild("Hit")
    if not hit then return nil end
    return hit:FindFirstChild("Nape")
end

local function findHumanoid(titan)
    local h = titan:FindFirstChildOfClass("Humanoid")
    if h then return h end
    for _, child in ipairs(titan:GetChildren()) do
        local hh = child:FindFirstChildOfClass("Humanoid")
        if hh then return hh end
    end
    return nil
end

local function restoreTitans()
    local titansFolder = Workspace:FindFirstChild("Titans")
    if titansFolder then
        for _, titan in ipairs(titansFolder:GetChildren()) do
            local nape = getNape(titan)
            if nape then
                local okAddr, addr = pcall(function() return nape.Address end)
                if okAddr and addr and OriginalSizes[addr] then
                    writePartSize(nape, OriginalSizes[addr])
                end
            end
        end
    end
    OriginalSizes = {}
end

local function getHRP()
    local okC, char = pcall(function() return LocalPlayer.Character end)
    if not (okC and char) then return nil end
    local okH, hrp = pcall(function() return char:FindFirstChild("HumanoidRootPart") end)
    if not (okH and hrp) then return nil end
    return hrp
end

local function performAttack()
    pcall(mouse1press)
    task.wait(0.06)
    pcall(mouse1release)
end

local function getTitanHeight(titan)
    local hrp
    pcall(function() hrp = titan:FindFirstChild("HumanoidRootPart") end)
    if hrp then
        local okSz, sz = pcall(function() return hrp.Size end)
        if okSz and sz and sz.Y then return sz.Y end
    end
    local nape = getNape(titan)
    if nape then
        local okP, p = pcall(function() return nape.Position end)
        if okP and p and p.Y then return p.Y end
    end
    return 0
end

local function getTallestLiveTitan()
    local titansFolder = Workspace:FindFirstChild("Titans")
    if not titansFolder then return nil, nil end
    local bestTitan, bestNape, bestH = nil, nil, -math.huge
    for _, titan in ipairs(titansFolder:GetChildren()) do
        if findHumanoid(titan) then
            local nape = getNape(titan)
            if nape then
                local h = getTitanHeight(titan)
                if h > bestH then
                    bestH = h; bestTitan = titan; bestNape = nape
                end
            end
        end
    end
    return bestTitan, bestNape
end

local function isTitanGrabbing(titan)
    if not titan then return false end
    local attrs
    pcall(function() attrs = titan:GetAttributes() end)
    if type(attrs) ~= "table" then return false end
    for k, v in pairs(attrs) do
        if v and string.find(string.lower(tostring(k)), "grab") then
            return true
        end
    end
    return false
end

local function getBladeSets()
    local pg     = LocalPlayer:FindFirstChild("PlayerGui")
    local iface  = pg     and pg:FindFirstChild("Interface")
    local hud    = iface  and iface:FindFirstChild("HUD")
    local main   = hud    and hud:FindFirstChild("Main")
    local top    = main   and main:FindFirstChild("Top")
    local seven  = top    and top:FindFirstChild("7")
    local blades = seven  and seven:FindFirstChild("Blades")
    local sets   = blades and blades:FindFirstChild("Sets")
    if not sets then return nil end
    local okT, txt = pcall(function() return sets.Text end)
    if not (okT and type(txt) == "string") then return nil end
    return tonumber(txt:match("(%d+)"))
end

local function getNearestRefill()
    local hrp = getHRP()
    if not hrp then return nil end
    local okP, pPos = pcall(function() return hrp.Position end)
    if not (okP and pPos) then return nil end

    local descs
    pcall(function() descs = Workspace:GetDescendants() end)
    if not descs then return nil end

    local bestPart, bestD2 = nil, math.huge
    for _, d in ipairs(descs) do
        local okN, name = pcall(function() return d.Name end)
        if okN and name == "Refill" then
            local par
            pcall(function() par = d.Parent end)
            local parName
            if par then pcall(function() parName = par.Name end) end
            if parName == "GasTanks" then
                local okR, rPos = pcall(function() return d.Position end)
                if okR and rPos then
                    local dx = pPos.X - rPos.X
                    local dy = pPos.Y - rPos.Y
                    local dz = pPos.Z - rPos.Z
                    local d2 = dx*dx + dy*dy + dz*dz
                    if d2 < bestD2 then bestD2 = d2; bestPart = d end
                end
            end
        end
    end
    return bestPart
end

local function snapshotPlayerNumericAttrs()
    local snap = {}
    local ok, attrs = pcall(function() return LocalPlayer:GetAttributes() end)
    if ok and type(attrs) == "table" then
        for k, v in pairs(attrs) do
            if type(k) == "number" and type(v) == "string" then
                local ok2, vv = pcall(function() return LocalPlayer:GetAttribute(v) end)
                if ok2 then
                    local n = tonumber(vv)
                    if n then snap[v] = n end
                end
            else
                local n = tonumber(v)
                if n then snap[tostring(k)] = n end
            end
        end
    end
    return snap
end

local function getRewardTimeTaken()
    local pg    = LocalPlayer:FindFirstChild("PlayerGui")
    local iface = pg    and pg:FindFirstChild("Interface")
    local rew   = iface and iface:FindFirstChild("Rewards")
    if not rew then return nil end
    local descs
    pcall(function() descs = rew:GetDescendants() end)
    if not descs then return nil end
    for _, d in ipairs(descs) do
        local okC, cn = pcall(function() return d.ClassName end)
        if okC and (cn == "TextLabel" or cn == "TextButton") then
            local okT, txt = pcall(function() return d.Text end)
            if okT and type(txt) == "string" then
                local mm, ss = txt:match("^%s*(%d+):(%d%d)%s*$")
                if mm and ss then
                    return tonumber(mm) * 60 + tonumber(ss)
                end
            end
        end
    end
    return nil
end

local function retryButtonExists()
    local pg     = LocalPlayer:FindFirstChild("PlayerGui")
    local iface  = pg     and pg:FindFirstChild("Interface")
    local rew    = iface  and iface:FindFirstChild("Rewards")
    local mainA  = rew    and rew:FindFirstChild("Main")
    local info   = mainA  and mainA:FindFirstChild("Info")
    local mainB  = info   and info:FindFirstChild("Main")
    local btns   = mainB  and mainB:FindFirstChild("Buttons")
    return btns and btns:FindFirstChild("Retry") ~= nil
end

local function getTitanCount()
    local count = 0
    local titansFolder = Workspace:FindFirstChild("Titans")
    if titansFolder then
        for _ in ipairs(titansFolder:GetChildren()) do count = count + 1 end
    end
    return count
end

local function tap(vk)
    pcall(keypress, vk)
    task.wait(0.08)
    pcall(keyrelease, vk)
end

-- ============================================================
-- AUTO KILL — drop+velocity slam pattern with grab bailout and
-- blade-stuck watchdog. Idles when no live titans (Waves mode).
-- ============================================================
task.spawn(function()
    while tick() - SCRIPT_LOAD_AT < ReadyDelay do task.wait(0.5) end

    local lastAttack = 0
    local activeTitan, activeNape = nil, nil
    local cycleCount = 0
    local lastBladeDecrement = tick()
    local prevBladeCount     = nil

    local function applyHitbox()
        local titansFolder = Workspace:FindFirstChild("Titans")
        if not titansFolder then return end
        local sizeVec = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
        for _, titan in ipairs(titansFolder:GetChildren()) do
            local nape = getNape(titan)
            if nape then
                local okAddr, addr = pcall(function() return nape.Address end)
                if okAddr and addr and not OriginalSizes[addr] then
                    local okSz, sz = pcall(function() return nape.Size end)
                    if okSz and sz then OriginalSizes[addr] = sz end
                end
                writePartSize(nape, sizeVec)
            end
        end
    end

    while Running do
        if RefillingNow then
            lastBladeDecrement = tick()
            prevBladeCount     = getBladeSets()
            task.wait(0.1)
        else
            -- No live titans → idle (Waves mode downtime).
            local titansFolder = Workspace:FindFirstChild("Titans")
            local hasLive = false
            if titansFolder then
                for _, t in ipairs(titansFolder:GetChildren()) do
                    if findHumanoid(t) then hasLive = true; break end
                end
            end
            if not hasLive then
                activeTitan, activeNape = nil, nil
                cycleCount = 0
                lastBladeDecrement = tick()
                task.wait(0.5)
            else
                applyHitbox()

                if not (activeTitan and findHumanoid(activeTitan)) then
                    activeTitan, activeNape = getTallestLiveTitan()
                    cycleCount = 0
                end

                -- Blade-stuck watchdog
                do
                    local sets = getBladeSets()
                    if sets then
                        if prevBladeCount and sets < prevBladeCount then
                            lastBladeDecrement = tick()
                        end
                        prevBladeCount = sets
                    end
                    if tick() - lastBladeDecrement > BladeStuckTimeout then
                        tap(0x52)   -- R
                        activeTitan, activeNape = nil, nil
                        cycleCount         = 0
                        lastBladeDecrement = tick()
                    end
                end

                if activeTitan and activeNape then
                    local hrp = getHRP()
                    local okN, npos = pcall(function() return activeNape.Position end)
                    if hrp and okN and npos then
                        if isTitanGrabbing(activeTitan) then
                            -- Grab bailout — TP up high, freeze 0.5s
                            pcall(function()
                                hrp.CFrame = CFrame.new(npos.X, npos.Y + DropHeight + 60, npos.Z)
                            end)
                            pcall(function() hrp.AssemblyLinearVelocity = Vector3.zero end)
                            pcall(function() hrp.Velocity = Vector3.zero end)
                            task.wait(0.5)
                            cycleCount = 0
                        else
                            -- Standard cycle — TP up, leave velocity alone
                            pcall(function()
                                hrp.CFrame = CFrame.new(npos.X, npos.Y + DropHeight, npos.Z)
                            end)

                            cycleCount = cycleCount + 1
                            if cycleCount >= AnchorEvery then
                                cycleCount = 0
                                pcall(function() hrp.AssemblyLinearVelocity = Vector3.zero end)
                                pcall(function() hrp.Velocity = Vector3.zero end)
                            end

                            if tick() - lastAttack >= KillCooldown then
                                performAttack()
                                lastAttack = tick()
                            end

                            -- Dwell with floor-check
                            local floorY  = npos.Y + FloorBuffer
                            local dwellEnd = tick() + DropDwell
                            while tick() < dwellEnd do
                                local h2 = getHRP()
                                if not h2 then break end
                                local okP, p = pcall(function() return h2.Position end)
                                if okP and p and p.Y <= floorY then break end
                                task.wait(0.015)
                            end
                        end
                    end
                else
                    task.wait(0.3)
                end
            end
        end
    end
end)

-- ============================================================
-- AUTO REFILL — TP to nearest gas tank when blades hit 0, R-spam
-- with attribute-snapshot success detection, then upthrow + dwell.
-- ============================================================
task.spawn(function()
    while tick() - SCRIPT_LOAD_AT < ReadyDelay do task.wait(0.5) end
    local zeroBladesAt = nil   -- tick() when sets first read 0
    while Running do
        if not RefillingNow and tick() >= refillCooldownUntil then
            local sets = getBladeSets()
            if sets == 0 then
                -- Hold off until blades have been 0 for BladesZeroDelay
                -- seconds — the HUD reads 0 once the 3 spare sets are
                -- spent, but the equipped 4th set still has blades.
                if not zeroBladesAt then zeroBladesAt = tick() end
            else
                zeroBladesAt = nil
            end

            if sets == 0 and zeroBladesAt
               and tick() - zeroBladesAt >= BladesZeroDelay then
                zeroBladesAt = nil
                local refill = getNearestRefill()
                if refill then
                    RefillingNow = true
                    local okP, rPos = pcall(function() return refill.Position end)
                    if okP and rPos then
                        local beforeAttrs = snapshotPlayerNumericAttrs()

                        local function anchor()
                            local h = getHRP()
                            if not h then return end
                            pcall(function()
                                h.CFrame = CFrame.new(rPos.X, rPos.Y + RefillHeight, rPos.Z)
                            end)
                            pcall(function() h.AssemblyLinearVelocity = Vector3.zero end)
                            pcall(function() h.Velocity = Vector3.zero end)
                        end

                        local function isOnTank()
                            local h = getHRP()
                            if not h then return false end
                            local okPP, pPos = pcall(function() return h.Position end)
                            if not (okPP and pPos) then return false end
                            local dx = pPos.X - rPos.X
                            local dz = pPos.Z - rPos.Z
                            return dx*dx + dz*dz <= RefillRange * RefillRange
                        end

                        -- Brief initial settle so the first TP has a
                        -- moment to register before we start polling.
                        for _ = 1, 3 do
                            anchor()
                            task.wait(RefillAnchorGap)
                        end

                        -- Combined re-anchor + R-spam + success poll.
                        -- Each tick: if we've drifted off the tank
                        -- (Auto Booster's space-spam, titan nudges,
                        -- ragdoll), re-anchor and HOLD R RELEASED.
                        -- Only fire R when we're actually within
                        -- RefillRange XZ of the tank — otherwise R
                        -- presses go to wherever we are and accomplish
                        -- nothing.
                        local refillSucceeded = false
                        local spamEnd   = tick() + RefillRSpamTime
                        local pollUntil = tick() + RefillRSpamTime + RefillPollTail
                        local rDown     = false

                        while tick() < pollUntil do
                            if not isOnTank() then
                                anchor()
                                if rDown then
                                    pcall(keyrelease, 0x52)
                                    rDown = false
                                end
                            elseif tick() < spamEnd then
                                if rDown then
                                    pcall(keyrelease, 0x52)
                                    rDown = false
                                else
                                    pcall(keypress, 0x52)
                                    rDown = true
                                end
                            elseif rDown then
                                pcall(keyrelease, 0x52)
                                rDown = false
                            end

                            local afterAttrs = snapshotPlayerNumericAttrs()
                            for k, v in pairs(beforeAttrs) do
                                local a = afterAttrs[k]
                                if a and a < v then
                                    refillSucceeded = true
                                    break
                                end
                            end
                            if refillSucceeded then break end
                            task.wait(RefillPollStep)
                        end
                        if rDown then pcall(keyrelease, 0x52) end

                        if refillSucceeded then
                            local h2 = getHRP()
                            if h2 then
                                local okPP, pPos = pcall(function() return h2.Position end)
                                if okPP and pPos then
                                    pcall(function()
                                        h2.CFrame = CFrame.new(pPos.X,
                                            pPos.Y + SafeSpotHeight, pPos.Z)
                                    end)
                                    pcall(function() h2.AssemblyLinearVelocity = Vector3.zero end)
                                    pcall(function() h2.Velocity = Vector3.zero end)
                                    task.wait(SafeSpotDwell)
                                end
                            end
                            refillFailures = 0
                            refillCooldownUntil = 0
                        else
                            refillFailures = refillFailures + 1
                            if refillFailures >= 3 then
                                refillCooldownUntil = tick() + 300   -- 5 min
                                refillFailures = 0
                                pcall(notify, "Auto Refill failed 3 times — pausing 5 minutes", "AOT:R", 4)
                            else
                                refillCooldownUntil = tick() + 2
                            end
                        end
                    end
                    RefillingNow = false
                end
            end
        end
        task.wait(0.5)
    end
end)

-- ============================================================
-- AUTO QTE — press whichever W/A/S/D shows up under
-- PlayerGui.Interface.Buttons.
-- ============================================================
local QTE_VK = { W = 0x57, A = 0x41, S = 0x53, D = 0x44 }
task.spawn(function()
    while Running do
        local buttons
        pcall(function() buttons = LocalPlayer.PlayerGui.Interface.Buttons end)
        if buttons then
            for key, vk in pairs(QTE_VK) do
                local folder
                pcall(function() folder = buttons:FindFirstChild(key) end)
                if folder then
                    pcall(keypress, vk)
                    task.wait(0.2)
                    pcall(keyrelease, vk)
                end
            end
        end
        task.wait()
    end
end)

-- ============================================================
-- AUTO BOOSTER — tap Space while above a live titan to chain dashes.
-- ============================================================
task.spawn(function()
    while tick() - SCRIPT_LOAD_AT < ReadyDelay do task.wait(0.5) end
    while Running do
        local hrp = getHRP()
        local titansFolder = Workspace:FindFirstChild("Titans")
        local onTitan = false
        if hrp and titansFolder then
            local okPP, pPos = pcall(function() return hrp.Position end)
            if okPP and pPos then
                for _, titan in ipairs(titansFolder:GetChildren()) do
                    if findHumanoid(titan) then
                        local nape = getNape(titan)
                        if nape then
                            local okN, npos = pcall(function() return nape.Position end)
                            if okN and npos then
                                local dx = pPos.X - npos.X
                                local dz = pPos.Z - npos.Z
                                local dy = pPos.Y - npos.Y
                                if dx*dx + dz*dz <= BoostXZRadius * BoostXZRadius
                                   and dy >= BoostMinY and dy <= BoostMaxY then
                                    onTitan = true
                                    break
                                end
                            end
                        end
                    end
                end
            end
        end
        if onTitan then
            pcall(keypress,   0x20)
            task.wait(0.04)
            pcall(keyrelease, 0x20)
            task.wait(BoostTapGap)
        else
            task.wait(0.15)
        end
    end
end)

-- ============================================================
-- AUTO RETRY — when "Mission Completed" rewards screen comes up
-- (or the kill loop has been stuck for 3 minutes), drive the GUI
-- nav: \ → D → D → Enter. queue_on_teleport reloads this script
-- on the new sub-place so the farm continues.
-- ============================================================
task.spawn(function()
    local lastFire = 0
    local firedThisSession = false

    while Running do
        local rewardsShowing = getRewardTimeTaken() ~= nil
        if not rewardsShowing then firedThisSession = false end

        local stuckMission = (tick() - lastKillAt) > StuckMissionAfter
                          and getTitanCount() > 0
        local fireOk = rewardsShowing or (stuckMission and not RefillingNow)

        if fireOk
           and not firedThisSession
           and (tick() - lastFire > 4.0)
           and retryButtonExists() then
            firedThisSession = true
            lastFire = tick()

            -- Re-inject after sub-place teleport.
            pcall(function()
                if queue_on_teleport then
                    queue_on_teleport(string.format([[
                        pcall(function()
                            if isfile and isfile(%q) then
                                loadstring(readfile(%q))()
                            end
                        end)
                    ]], SelfPath, SelfPath))
                end
            end)

            -- \ → D → D → Enter
            tap(0xDC)
            task.wait(0.3)
            tap(0x44)
            task.wait(0.3)
            tap(0x44)
            task.wait(0.3)
            tap(0x0D)
        end
        task.wait(0.5)
    end
end)

-- ============================================================
-- KILL TRACKER — feeds the stuck-mission watchdog.
-- ============================================================
task.spawn(function()
    local lastTitanState = {}
    while Running do
        task.wait(0.5)
        local folder = Workspace:FindFirstChild("Titans")
        if folder then
            local seen = {}
            for _, titan in ipairs(folder:GetChildren()) do
                local okA, addr = pcall(function() return titan.Address end)
                if okA and addr then
                    seen[addr] = true
                    local alive = findHumanoid(titan) ~= nil
                    if lastTitanState[addr] == true and not alive then
                        lastKillAt = tick()
                    end
                    lastTitanState[addr] = alive
                end
            end
            for addr in pairs(lastTitanState) do
                if not seen[addr] then lastTitanState[addr] = nil end
            end
        end
    end
end)

-- ============================================================
-- END KEY — unload (rising-edge so the press at boot doesn't fire)
-- ============================================================
task.spawn(function()
    local wasDown = false
    local ready   = false
    while Running do
        local down = iskeypressed(0x23)
        if not ready then
            if not down then ready = true end
        elseif down and not wasDown then
            Running = false
            pcall(restoreTitans)
            pcall(notify, "AOT:R standalone unloaded", "AOT:R", 3)
            return
        end
        wasDown = down
        task.wait(0.05)
    end
end)

pcall(notify, "AOT:R standalone loaded — 8s warmup. End to unload.", "AOT:R", 4)
