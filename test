    mtxt.Text = isListening and "..." or getKeyName(currentVK)
    mtxt.Color = Colors.TextPrimary; mtxt.Size = 11
    mtxt.Font = Drawing.Fonts.SystemBold
    mtxt.Center = true; mtxt.Outline = false
    mtxt.Visible = true; mtxt.ZIndex = zb + 5
    table.insert(GUI.ContentElements, mtxt)

    table.insert(GUI.Clickables, {
        x = bx, y = by, w = bw, h = bh,
        hover = { el = mbg, base = mbgColor },
        onClick = function()
            ListeningForBind = listenId
