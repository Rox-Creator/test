-- Helper: tiny bind pill next to a feature toggle (like Bridger's
-- AutoFish hotkey pill).
local function drawHotkeyPill(cardX, cardW, fY, currentVK, listenId, zb)
    local togX = cardX + cardW - Config.CardPad - Config.ToggleW
    local bw, bh = 32, 16
    local bx = togX - bw - 16
    local by = fY + 1
    local isListening = (ListeningForBind == listenId)

    -- See DrawBindButton: we capture the color in a local rather
    -- than reading it back off the Drawing instance, so the hover
    -- table holds a real Color3 (not a nil that crashes lighten()).
    local mbgColor = isListening and Colors.AccentRed or Colors.ToggleOff
    local mbg = Drawing.new("Square")
    mbg.Position = Vector2.new(bx, by); mbg.Size = Vector2.new(bw, bh)
    mbg.Color = mbgColor
    mbg.Filled = true; mbg.Corner = 4
    mbg.Visible = true; mbg.ZIndex = zb + 3
